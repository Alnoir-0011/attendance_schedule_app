# PostgreSQL（Neon）
# DATABASE_URL: アプリ実行用（プーラー経由）。neonctl connection-string main --pooled で取得
# DIRECT_URL:   マイグレーション用（直接接続）。neonctl connection-string main で取得
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET="openssl rand -base64 32 などで生成したランダム文字列"
BETTER_AUTH_URL="http://localhost:3000"

# テスト用 DB は .env.test に同じキーで定義する（Neon の test ブランチを使用）
# 取得方法: neonctl connection-string test
